# Frontend Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Frontend -> backend API
NEXT_PUBLIC_API_BASE=http://localhost:3001/api/vertex
NEXT_PUBLIC_ML_API_BASE=http://localhost:3001/api

# Backend app
PORT=3001
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=backend/vertex-key.json

# Polygon / blockchain
RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0x_your_wallet_private_key
CONTRACT_ADDRESS=0xYourTrustContract
ESCROW_CONTRACT_ADDRESS=0xYourEscrowContract
