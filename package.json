{
  "name": "techlance-nextjs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev frontend",
    "dev:backend": "node --import tsx backend/server.js",
    "dev:all": "npm run dev:backend & npm run dev",
    "build": "next build frontend",
    "start": "next start frontend",
    "start:backend": "node --import tsx backend/server.js",
    "clean": "node -e \"require('fs').rmSync('frontend/.next', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit -p frontend/tsconfig.json",
    "firebase:rules": "firebase deploy --only firestore:rules",
    "firebase:indexes": "firebase deploy --only firestore:indexes",
    "seed:firestore": "node --import tsx backend/scripts/seed-firestore.js",
    "ml:export-ranking-data": "node scripts/export-ranking-data.mjs",
    "ml:export-project-success-data": "node scripts/export-project-success-data.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^11.11.0",
    "google-auth-library": "^9.0.0",
    "firebase": "^11.10.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
